# Copy to .env for local dev. In production (Render/Railway/Fly), set these as
# real environment variables in the host's dashboard — never commit .env.

PORT=8787

# Supabase project (Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SECRET — service role key, server-only. Never expose to the app/client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional. Defaults to on — set to "false" to stop writing to message_transfer_log.
ENABLE_TRANSFER_LOG=true

# Optional — TURN relay fallback for calling on strict NATs (see docs/SETUP.md
# section 3.5). Calling works STUN-only if these are left unset.
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
