# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.keystore
*.mobileprovision
/credentials/

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files (never commit real Supabase/Firebase credentials)
.env
.env.*
!.env.example

# Firebase native config: intentionally NOT gitignored. These identify the
# Firebase project (API key, app ID) but aren't secrets in the access-control
# sense — Firebase's security model relies on Auth + Security Rules + API key
# restrictions, not on this file staying private. EAS Build archives only
# what .gitignore doesn't exclude, so keeping these tracked is what lets a
# cloud build actually find them during the Firebase config-plugin step.
# (Actual secrets — Supabase service role key, GitHub/EAS tokens — stay in
# .env / EAS environment variables, never here.)

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
