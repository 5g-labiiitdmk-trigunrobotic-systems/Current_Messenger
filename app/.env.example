# Copy this file to .env and fill in real values.
# These are inlined at build time by Expo (EXPO_PUBLIC_* is safe to expose client-side —
# it's the anon/public key, never the service role key).

# Supabase project (Settings -> API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# WebSocket relay server (see /server) — wss:// in production, ws:// for local dev
EXPO_PUBLIC_RELAY_WS_URL=ws://localhost:8787

# MapTiler (https://www.maptiler.com) — powers the map tiles shown for shared
# locations on Android (iOS uses Apple MapKit natively, no key needed). Free
# tier: 100,000 tile loads/month, no card required, built for exactly this
# kind of app usage — unlike tile.openstreetmap.org (the free volunteer-run
# server this app used previously, until it started blocking this app's
# traffic for not following its production-usage policy). This key is safe
# to ship in the client bundle like the Supabase anon key above — MapTiler's
# keys are designed for direct client embedding and can be domain/bundle-ID
# restricted from their dashboard, unlike TURN_URLS/TURN_USERNAME/
# TURN_CREDENTIAL (server/.env), which are genuine shared-secret relay
# credentials that must never appear in the app bundle. See docs/SETUP.md
# section 3.6. Leave unset and shared-location messages fall back to a
# plain coordinate bubble instead of a map (same as web/malformed data).
EXPO_PUBLIC_MAPTILER_API_KEY=

# Firebase Phone Auth is configured natively via GoogleService-Info.plist (iOS) and
# google-services.json (Android) — see docs/SETUP.md. No JS env vars needed for it.
